# 复制本文件为 .env 并填入你的火山方舟 Agent Plan Key。
# 也可以直接从 E:\github\test-agent-plan\.env 拷贝过来（同一套 Key）。
AGENT_API_KEY=your_agent_plan_api_key_here

# ==== 图片生成 (Volcengine Ark - 豆包 Seedream) ====
ARK_IMAGE_MODEL=doubao-seedream-5.0-lite
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
IMAGE_SIZE=2K
IMAGE_OUTPUT_FORMAT=png
IMAGE_RESPONSE_FORMAT=url
IMAGE_WATERMARK=false

# ==== 文本大模型 (LLM - Ark Chat) ====
PROMPT_MODEL=ark-code-latest
PROMPT_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3

# ==== 视觉大模型 (仅 make_doc_video.py / make_narration_video.py 需要，识别 mp4 抽帧内容) ====
# 需要账户已在火山方舟开通对应模型。常见可选值：
#   doubao-seed-1.6-flash           便宜、速度快，日常使用
#   doubao-seed-2-1-pro-260628      强模型，识别更准（推荐；需创建接入点拿到 ep-xxx id）
#   doubao-1.5-vision-pro-32k       上一代 Pro
VISION_MODEL=doubao-seed-1.6-flash

# —— 可选：把视觉大模型独立走另一把 key / 另一条 base_url ——
# 用于"文本 LLM 走 agent-plan、视觉走标准 Ark 接入点"的混合部署。
# 都不填时，视觉会回落到 AGENT_API_KEY + PROMPT_BASE_URL（与文本共用）。
# 常见用法：agent-plan 套餐不支持视觉时，在标准 Ark 单独开一个视觉接入点填在这里。
VISION_API_KEY=
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 可选：配一个 Pro 模型用于 --vision-model pro 切换（填接入点 id ep-xxx 或模型名）
VISION_MODEL_PRO=
#   VISION_MODEL_PRO=

# ==== TTS 语音合成 (字节 Seed-TTS) ====
TTS_API_URL=https://openspeech.bytedance.com/api/v3/plan/tts/unidirectional
TTS_RESOURCE_ID=seed-tts-2.0
TTS_SPEAKER=zh_female_vv_uranus_bigtts
TTS_FORMAT=mp3
TTS_SAMPLE_RATE=24000

# ==== 输出目录（换机器 / 换用户主要改这里） ====
# 剪映草稿根目录：Windows 常见 D:/software/JianyingPro Drafts
# 想知道自己剪映的草稿目录：剪映 → 全局设置 → 草稿位置
JIANYING_DRAFT_FOLDER=D:/software/JianyingPro Drafts

# 项目产物根目录（logs / 中间产物 / 模糊背景缓存 / 各流水线草稿输入等都在下面）
# 留空则用 <项目根>/outputs；想搬外置盘可写绝对路径，如 E:/video-outputs
OUTPUTS_ROOT=
